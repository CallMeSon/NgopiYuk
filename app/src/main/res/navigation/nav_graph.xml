<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.android.ngopiyuk.fragment.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboard_to_coffeeDetail"
            app:destination="@id/coffeeDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/pemesananFragment"
        android:name="com.android.ngopiyuk.fragment.PemesananFragment"
        android:label="Pemesanan"
        tools:layout="@layout/fragment_pemesanan" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.android.ngopiyuk.fragment.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.android.ngopiyuk.fragment.FavoritesFragment"
        android:label="Favorit"
        tools:layout="@layout/fragment_favorites">
        <action
            android:id="@+id/action_favorites_to_coffeeDetail"
            app:destination="@id/coffeeDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.android.ngopiyuk.fragment.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/aboutFragment"
        android:name="com.android.ngopiyuk.fragment.AboutFragment"
        android:label="About"
        tools:layout="@layout/fragment_about" />

    <fragment
        android:id="@+id/coffeeDetailFragment"
        android:name="com.android.ngopiyuk.fragment.CoffeeDetailFragment"
        android:label="Detail Kopi"
        tools:layout="@layout/fragment_coffee_detail">
        <argument
            android:name="coffee"
            app:argType="com.android.ngopiyuk.model.Coffee" />
    </fragment>

</navigation>
