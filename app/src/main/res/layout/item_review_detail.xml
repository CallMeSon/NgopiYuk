<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="#FAF6F4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Circular Avatar -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/coffee_primary">

                <TextView
                    android:id="@+id/tvAvatarInitials"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="JD" />

            </androidx.cardview.widget.CardView>

            <!-- Name and Stars -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvReviewName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/coffee_dark"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Jane Doe" />

                <!-- Dynamic Stars Row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imgStar1"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="2dp"
                        android:contentDescription="Star"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="#FFB300" />

                    <ImageView
                        android:id="@+id/imgStar2"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="2dp"
                        android:contentDescription="Star"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="#FFB300" />

                    <ImageView
                        android:id="@+id/imgStar3"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="2dp"
                        android:contentDescription="Star"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="#FFB300" />

                    <ImageView
                        android:id="@+id/imgStar4"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="2dp"
                        android:contentDescription="Star"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="#FFB300" />

                    <ImageView
                        android:id="@+id/imgStar5"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:contentDescription="Star"
                        android:src="@android:drawable/btn_star_big_off"
                        app:tint="#D4C3BE" />

                </LinearLayout>

            </LinearLayout>

            <!-- Time Ago -->
            <TextView
                android:id="@+id/tvReviewTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:textColor="@color/gray_text"
                android:textSize="11sp"
                tools:text="2 days ago" />

        </LinearLayout>

        <!-- Comment Text -->
        <TextView
            android:id="@+id/tvReviewComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingMultiplier="1.2"
            android:textColor="@color/coffee_dark"
            android:textSize="13sp"
            tools:text="The atmosphere here is unmatched. Perfect place for working or just chilling with friends. The Senja Latte is a must-try!" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
