<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/margin_small"
    android:layout_marginEnd="@dimen/margin_small"
    android:layout_marginBottom="@dimen/margin_small"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/padding_standard">

        <!-- Shop Image -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgShop"
            android:layout_width="@dimen/shop_image_size"
            android:layout_height="@dimen/shop_image_size"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.MediumComponent"
            tools:src="@tools:sample/avatars" />

        <!-- Shop Name -->
        <TextView
            android:id="@+id/tvShopName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_medium"
            android:layout_marginEnd="@dimen/margin_small"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/coffee_dark"
            android:textSize="@dimen/text_subheader"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btnBookmark"
            app:layout_constraintStart_toEndOf="@id/imgShop"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Roast &amp; Revel" />

        <!-- Bookmark Icon -->
        <ImageView
            android:id="@+id/btnBookmark"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="Bookmark"
            android:src="@android:drawable/btn_star_big_off"
            app:tint="@color/bookmark_inactive"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Rating Row: ★ 4.6 (1.2k) -->
        <LinearLayout
            android:id="@+id/ratingRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="@id/tvShopName"
            app:layout_constraintTop_toBottomOf="@id/tvShopName">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:contentDescription="Rating"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="#FFB300" />

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/coffee_dark"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                tools:text="4.6" />

            <TextView
                android:id="@+id/tvReviewCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/gray_text"
                android:textSize="@dimen/text_body"
                tools:text="(1.2k)" />

        </LinearLayout>

        <!-- Distance + Price Row -->
        <LinearLayout
            android:id="@+id/infoRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvShopName"
            app:layout_constraintTop_toBottomOf="@id/ratingRow">

            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/gray_text"
                android:textSize="@dimen/text_body"
                tools:text="0.8 km" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="•"
                android:textColor="@color/gray_text"
                android:textSize="@dimen/text_body" />

            <TextView
                android:id="@+id/tvPriceLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/gray_text"
                android:textSize="@dimen/text_body"
                tools:text="$$" />

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Category Badge -->
            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_category_badge"
                android:paddingStart="@dimen/badge_padding_horizontal"
                android:paddingTop="@dimen/badge_padding_vertical"
                android:paddingEnd="@dimen/badge_padding_horizontal"
                android:paddingBottom="@dimen/badge_padding_vertical"
                android:textAllCaps="true"
                android:textColor="@color/badge_green_text"
                android:textSize="@dimen/text_label"
                android:textStyle="bold"
                tools:text="FAST ROAST" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
