<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/coffee_light"
    android:orientation="vertical">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/container_padding"
        android:layout_marginTop="@dimen/margin_medium"
        android:layout_marginBottom="@dimen/margin_medium"
        android:text="@string/vouchers_title"
        android:textColor="@color/coffee_dark"
        android:textSize="@dimen/text_header"
        android:textStyle="bold" />

    <!-- Voucher List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvVouchers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="@dimen/container_padding"
        android:paddingEnd="@dimen/container_padding"
        android:paddingBottom="@dimen/margin_medium" />

</LinearLayout>
